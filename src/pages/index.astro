---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import config from '../config.json';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = sortedPosts.find(post => post.data.featured) || sortedPosts[0];
const otherPosts = sortedPosts.filter(post => post.slug !== featuredPost.slug);

---

<Layout title={`${config.siteTitle} - ${config.siteDescription}`}>
	
	<!-- Hero Section -->
	<section class="container mx-auto px-4 py-12">
        <div class="bg-white group dark:bg-black">
            <div class="grid md:grid-cols-2">
                <div class="h-64 md:h-auto relative overflow-hidden">
                    <img 
                        src={featuredPost.data.image?.url} 
                        alt={featuredPost.data.image?.alt}
                        class="w-full h-full object-cover transition-all duration-300"
                    />
                    <div class="absolute top-0 left-0 bg-404-pink text-white text-sm font-mono font-bold px-3 py-1 uppercase tracking-wide">
                        Featured Story
                    </div>
                </div>
                <div class="p-8 md:p-12 flex flex-col justify-center bg-white relative dark:bg-black">
                    <a href={`/category/${featuredPost.data.category.toLowerCase()}`} class="absolute top-4 left-4 font-mono text-xs text-gray-500 uppercase tracking-widest px-2 py-0.5 rounded-full hover:bg-black hover:text-white transition-colors dark:text-gray-400 dark:hover:bg-white dark:hover:text-black">
                         {featuredPost.data.category}
                    </a>
                    
                    <div class="text-xs font-mono font-bold mb-4 flex items-center gap-2 text-black dark:text-white">
                        <span class="w-2 h-2 bg-black rounded-full animate-pulse dark:bg-white"></span>
                        {featuredPost.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()}
                         {config.enableAuthor && <>// BY <a href={`/author/${featuredPost.data.author}`} class="hover:underline">{featuredPost.data.author.toUpperCase()}</a></>}
                    </div>
                    
                    <h2 class="text-3xl md:text-5xl font-bold text-black mb-6 leading-none tracking-tight uppercase dark:text-white">
                        <a href={`/posts/${featuredPost.slug}`} class="hover:text-404-pink transition-colors decoration-4 underline-offset-4 hover:underline">
                            {featuredPost.data.title}
                        </a>
                    </h2>
                    
                    <p class="font-serif text-lg leading-relaxed text-gray-800 mb-8 pl-4 dark:text-gray-300">
                        {featuredPost.data.description}
                    </p>
                    
                    <div>
                        <a href={`/posts/${featuredPost.slug}`} class="inline-block bg-black text-white font-mono font-bold px-6 py-3 hover:bg-white hover:text-black transition-all uppercase tracking-wider dark:bg-white dark:text-black dark:hover:bg-black dark:hover:text-white">
                            Read Full Story >>
                        </a>
                    </div>
                </div>
            </div>
        </div>
	</section>

    <!-- About / Intro Section -->
    <section class="w-full relative py-32 my-20 text-white transform -skew-y-3 bg-black origin-center dark:bg-white dark:text-black">
        
        <div class="container mx-auto px-4 relative z-10 flex flex-col md:flex-row items-center justify-between gap-12 text-center md:text-left transform skew-y-3">
             <div class="flex-1">
                 <h3 class="font-bold text-4xl md:text-6xl uppercase mb-6 leading-none tracking-tighter">
                    {config.introSection.title}<span class="text-white dark:text-black">.</span>
                 </h3>
                 <p class="font-mono text-base md:text-lg text-gray-300 max-w-2xl leading-relaxed border-l-4 border-white pl-6 dark:text-gray-700 dark:border-black">
                     {config.introSection.text}
                 </p>
             </div>
             <div class="flex-shrink-0">
                 <a href={config.introSection.linkUrl} class="inline-block bg-white text-black font-mono font-bold px-8 py-4 border-4 border-black hover:bg-black hover:text-white hover:border-white transition-all shadow-[8px_8px_0_0_#fff] hover:shadow-[4px_4px_0_0_#fff] uppercase tracking-widest text-sm transform rotate-2 hover:rotate-0 dark:bg-black dark:text-white dark:border-white dark:hover:bg-white dark:hover:text-black dark:hover:border-black dark:shadow-[8px_8px_0_0_#000] dark:hover:shadow-[4px_4px_0_0_#000]">
                     {config.introSection.linkText}
                 </a>
             </div>
        </div>
    </section>

	<!-- Latest Stories Grid -->
	<section class="container mx-auto px-4 py-8 mb-20">
        <div class="flex items-center justify-between mb-8 border-b-4 border-black pb-4 dark:border-white">
            <h2 class="text-3xl font-bold text-black uppercase tracking-tighter dark:text-white">Latest Signals</h2>
        </div>
        
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			{otherPosts.map(post => (
				<article class="flex flex-col h-full hover:translate-x-1 hover:-translate-y-1 transition-transform duration-200">
					<div class="h-48 overflow-hidden relative group">
						<img 
							src={post.data.image?.url} 
							alt={post.data.image?.alt}
							class="w-full h-full object-cover transition-all duration-500"
						/>
					</div>
					<div class="pt-6 flex flex-col flex-grow">
                        <div class="font-mono text-[10px] text-gray-500 mb-3 uppercase tracking-wider border-b border-gray-200 pb-2 flex items-center gap-2 dark:border-gray-700">
                            <span class="dark:text-gray-400">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                            <span class="text-gray-300 dark:text-gray-600">/</span>
                            <a href={`/category/${post.data.category.toLowerCase()}`} class="font-bold text-black underline hover:text-404-pink transition-colors dark:text-white dark:hover:text-404-pink">
                                {post.data.category}
                            </a>
                        </div>
                        
						<h3 class="text-xl font-bold text-black mb-3 leading-tight uppercase">
							<a href={`/posts/${post.slug}`} class="hover:text-404-pink transition-colors dark:text-white dark:hover:text-404-pink">
								{post.data.title}
							</a>
						</h3>

                        <p class="font-serif text-sm text-gray-600 mb-4 line-clamp-3 flex-grow dark:text-gray-400">
                            {post.data.description}
                        </p>
						
                        <div class="pt-4 mt-auto">
                            <a href={`/posts/${post.slug}`} class="text-sm font-mono font-bold text-black hover:text-404-pink hover:underline decoration-2 underline-offset-4 flex items-center gap-2 dark:text-white dark:hover:text-404-pink">
                                READ STORY <span>-></span>
                            </a>
                        </div>
					</div>
				</article>
			))}
		</div>
	</section>
    
    <!-- Newsletter Section -->
    <section class="bg-404-yellow border-y-4 border-black py-20 relative overflow-hidden">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 20px 20px;"></div>
        
        <div class="container mx-auto px-4 text-center max-w-3xl relative z-10">
            <div class="inline-block bg-black text-white font-mono text-xs px-2 py-1 mb-4 uppercase transform -rotate-3">
                No Algorithms. Just Truth.
            </div>
            <h2 class="text-4xl md:text-6xl font-bold mb-6 uppercase tracking-tighter text-black">
                Join the <span class="text-white bg-black px-2">Resistance</span>
            </h2>
            <p class="font-serif text-xl mb-10 text-black max-w-2xl mx-auto">
                Get our investigations, scoops, and analysis delivered directly to your inbox. Support independent tech journalism.
            </p>
            <form class="flex flex-col sm:flex-row gap-4 max-w-xl mx-auto">
                <input type="email" placeholder="ENTER YOUR EMAIL..." class="flex-grow px-6 py-4 bg-white text-black font-mono border-4 border-black focus:outline-none focus:ring-0 placeholder:text-gray-400" />
                <button type="button" class="bg-black text-white px-8 py-4 font-bold border-4 border-black hover:bg-white hover:text-black transition-colors uppercase tracking-widest shadow-[4px_4px_0_0_#fff]">
                    Subscribe
                </button>
            </form>
        </div>
    </section>

</Layout>
