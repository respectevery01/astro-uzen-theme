---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import config from '../../config.json';
import SocialShare from '../../components/SocialShare.astro';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
	<article class="container mx-auto px-4 py-12 max-w-4xl">
        <header class="mb-12 border-b-4 border-black pb-8">
            <div class="mb-4 flex items-center gap-4">
                <span class="bg-404-pink text-white text-xs font-mono font-bold px-3 py-1 border border-black uppercase tracking-wide">
                    {post.data.category}
                </span>
                <span class="font-mono text-xs text-gray-500 uppercase">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                    })}
                </span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold text-black mb-6 leading-none uppercase tracking-tighter dark:text-white">
                {post.data.title}
            </h1>
            <div class="flex items-center gap-4 text-sm font-mono border-t border-gray-200 pt-4 dark:border-gray-700">
                {config.enableAuthor && (
                    <>
                        <span class="font-bold text-black uppercase dark:text-white">By <a href={`/author/${post.data.author}`} class="hover:underline hover:text-404-pink transition-colors">{post.data.author}</a></span>
                        <span class="text-gray-300 dark:text-gray-600">|</span>
                    </>
                )}
                <span class="text-gray-500 dark:text-gray-400">4 MIN READ</span>
            </div>
        </header>

        {post.data.image && (
            <div class="mb-12 border-4 border-black shadow-brutal bg-gray-100">
                <img 
                    src={post.data.image.url} 
                    alt={post.data.image.alt} 
                    class="w-full h-auto object-cover max-h-[600px] transition-all duration-500"
                />
                <div class="bg-black text-white text-xs font-mono p-2 text-right">
                    IMG: {post.data.image.alt.toUpperCase()}
                </div>
            </div>
        )}

		<div class="prose prose-lg prose-slate mx-auto max-w-none 
            prose-headings:font-bold prose-headings:uppercase prose-headings:tracking-tight prose-headings:text-black dark:prose-headings:text-white
            prose-p:font-serif prose-p:text-gray-800 prose-p:leading-relaxed dark:prose-p:text-gray-300
            prose-a:text-404-pink prose-a:font-bold prose-a:no-underline hover:prose-a:underline hover:prose-a:decoration-2 hover:prose-a:underline-offset-4
            prose-blockquote:border-l-4 prose-blockquote:border-404-yellow prose-blockquote:bg-gray-50 prose-blockquote:p-4 prose-blockquote:font-mono prose-blockquote:not-italic prose-blockquote:text-sm dark:prose-blockquote:bg-gray-900 dark:prose-blockquote:text-gray-300
            prose-img:border-2 prose-img:border-black prose-img:shadow-brutal-sm dark:prose-img:border-white
            dark:prose-li:text-gray-300 dark:prose-ul:text-gray-300 dark:prose-ol:text-gray-300 dark:prose-strong:text-white
            dark:prose-code:text-404-pink dark:prose-code:bg-gray-800 dark:prose-code:px-1 dark:prose-code:rounded
            dark:prose-table:text-gray-300 dark:prose-th:text-white dark:prose-td:border-gray-700">
			<Content />
		</div>
        
        <div class="mt-16 pt-8 border-t-4 border-black dark:border-white">
            <div class="bg-404-gray p-8 border-2 border-black text-center dark:bg-gray-900 dark:border-white">
                <h3 class="font-bold uppercase mb-4 dark:text-white">Share this story</h3>
                <SocialShare />
            </div>
        </div>
	</article>
</Layout>

<style is:global>
    /* macOS Terminal Style for Code Blocks */
    .prose pre {
        position: relative;
        padding-top: 3rem;
        border-radius: 0.5rem;
        background-color: #1e1e1e; /* Dark background */
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border: 1px solid #333;
    }

    .prose pre::before {
        content: "";
        position: absolute;
        top: 1rem;
        left: 1rem;
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 50%;
        background-color: #ff5f56; /* Red */
        box-shadow: 1.25rem 0 0 #ffbd2e, 2.5rem 0 0 #27c93f; /* Yellow and Green */
    }

    /* Optional: Adjust code text color/font if needed */
    .prose pre code {
        font-family: 'Space Mono', monospace;
        font-size: 0.875rem;
        line-height: 1.5;
    }
    
    /* Ensure code block content doesn't overlap with the "buttons" */
    .prose pre > code {
        display: block;
    }
</style>
