---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
	title: string;
    description?: string;
}

const { title, description = "Tech, hacking, and the internet." } = Astro.props;

// Favicon detection logic
const publicDir = path.join(process.cwd(), 'public');
let favicon = { href: '/favicon.svg', type: 'image/svg+xml' };

if (fs.existsSync(path.join(publicDir, 'favicon.jpg'))) {
    favicon = { href: '/favicon.jpg', type: 'image/jpeg' };
} else if (fs.existsSync(path.join(publicDir, 'favicon.png'))) {
    favicon = { href: '/favicon.png', type: 'image/png' };
} else if (fs.existsSync(path.join(publicDir, 'favicon.svg'))) {
    favicon = { href: '/favicon.svg', type: 'image/svg+xml' };
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type={favicon.type} href={favicon.href} />
		<meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,700;1,300;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
		<title>{title}</title>
        <script is:inline>
            // Check for dark mode preference
            if (
              localStorage.getItem('color-theme') === 'dark' ||
              (!('color-theme' in localStorage) &&
                window.matchMedia('(prefers-color-scheme: dark)').matches)
            ) {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
        </script>
	</head>
	<body class="bg-white text-black dark:bg-black dark:text-white font-sans min-h-screen flex flex-col selection:bg-404-pink selection:text-white overflow-x-hidden">
		<Header />
        <main class="flex-grow">
		    <slot />
        </main>
        <Footer />
	</body>
</html>

<style is:global>
    /* macOS Terminal Style for Code Blocks */
    .prose pre {
        position: relative;
        padding-top: 3rem;
        border-radius: 0.5rem;
        background-color: #1e1e1e; /* Dark background */
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border: 1px solid #333;
    }

    /* Dark mode override for code blocks to ensure consistency */
    :global(.dark) .prose pre {
        background-color: #000 !important;
        border: 1px solid #333 !important; /* White border for high contrast */
        box-shadow: none !important;
    }
    
    /* Ensure code block content has transparent background so parent color shows */
    :global(.dark) .prose pre code,
    :global(.dark) .prose pre code span {
        background-color: transparent !important;
    }

    .prose pre::before {
        content: "";
        position: absolute;
        top: 1rem;
        left: 1rem;
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 50%;
        background-color: #ff5f56; /* Red */
        box-shadow: 1.25rem 0 0 #ffbd2e, 2.5rem 0 0 #27c93f; /* Yellow and Green */
    }

    /* Optional: Adjust code text color/font if needed */
    .prose pre code {
        font-family: 'Space Mono', monospace;
        font-size: 0.875rem;
        line-height: 1.5;
    }
    
    /* Ensure code block content doesn't overlap with the "buttons" */
    .prose pre > code {
        display: block;
    }
</style>
