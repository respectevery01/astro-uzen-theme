---
import config from '../config.json';
import SocialShare from './SocialShare.astro';
---

<footer class="bg-black text-white pt-16 pb-8 dark:bg-white dark:text-black">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-4xl font-mono font-bold mb-6 text-404-pink">{config.siteTitle}.</h3>
        <p class="font-mono text-gray-300 max-w-sm mb-8 dark:text-gray-700">
          {config.siteDescription}
        </p>
        <div>
            <SocialShare />
        </div>
      </div>
      
      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider border-b border-gray-800 pb-2 dark:text-black dark:border-gray-200">Sections</h4>
        <ul class="space-y-3 font-mono text-sm text-gray-300 dark:text-gray-700">
            {config.footer.sections.map(link => (
                <li><a href={link.href} class="hover:text-white transition-colors dark:hover:text-black">>> {link.label}</a></li>
            ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider border-b border-gray-800 pb-2 dark:text-black dark:border-gray-200">Legal</h4>
        <ul class="space-y-3 font-mono text-sm text-gray-300 dark:text-gray-700">
            {config.footer.legal.map(link => (
                <li><a href={link.href} class="hover:text-white transition-colors dark:hover:text-black">{link.label}</a></li>
            ))}
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center font-mono text-xs text-gray-500 dark:border-gray-200 dark:text-gray-500">
      <div>&copy; {new Date().getFullYear()} {config.siteTitle}. All rights reserved.</div>
      </div>
    </div>
  </div>
</footer>
